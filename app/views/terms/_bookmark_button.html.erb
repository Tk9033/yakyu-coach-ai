<% bookmark = current_user.bookmarks.find_by(ai_result_id: result.id) if user_signed_in? %>

<% if bookmark %>

  <%= button_to bookmark_path(bookmark),
      method: :delete,
      class: "text-yellow-400 text-2xl bg-transparent border-none" do %>
    ★
  <% end %>

<% else %>

  <%= button_to bookmarks_path(ai_result_id: result.id),
      method: :post,
      class: "text-gray-300 text-2xl bg-transparent border-none" do %>
    ☆
  <% end %>

<% end %>