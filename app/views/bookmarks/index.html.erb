<% content_for :header_title, "ブックマーク一覧" %>

<div class="max-w-md mx-auto px-4 py-8">

  <div class="flex items-center gap-2 mb-6 border-b pb-2 text-gray-800">
    <h1 class="text-xl font-bold">保存した用語</h1>
  </div>

  <% if @bookmarks.any? %>
    <div class="space-y-4">

      <% @bookmarks.each do |bookmark| %>
        <div id="bookmark_<%= bookmark.id %>" class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">

          <div class="flex-1">
            <div class="font-bold text-lg text-gray-900">
              <%= link_to bookmark.ai_result.term || "用語の解説",
                  ai_result_path(bookmark.ai_result),
                  class: "block py-1 hover:text-blue-600 hover:underline" %>
            </div>

            <div class="mt-1">
              <span class="px-2 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded-full">
                理解度： <%= level_label(bookmark.ai_result.level) %>
              </span>
            </div>
          </div>

          <div class="ml-4">
            <%# ブックマーク削除ボタン %>
            <%= button_to bookmark_path(bookmark),
                  method: :delete,
                  data: { turbo_confirm: "ブックマークを解除しますか？" },
                  class: "p-2 text-gray-300 hover:text-red-500 transition" do %>

              <svg xmlns="http://www.w3.org/2000/svg"
                   class="h-5 w-5"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke="currentColor">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>

            <% end %>
          </div>

        </div>
      <% end %>

    </div>

  <% else %>
    <div class="text-center py-20 bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200">
      <p class="text-gray-500 font-medium">まだブックマークはありません</p>

      <%= link_to "トップに戻る",
            root_path,
            class: "mt-4 inline-block text-blue-600 font-bold hover:underline" %>
    </div>
  <% end %>

</div>